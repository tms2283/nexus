# PBSP Configuration
PBSP_API_KEY=change-me-to-a-secure-random-string
PBSP_HOST=127.0.0.1
PBSP_PORT=8002
PBSP_DB_PATH=data/pbsp.db
PBSP_LOG_DIR=data/logs
PBSP_DEBUG=false

# Nexus Integration
NEXUS_SERVER_URL=http://localhost:3000

# Polling intervals (seconds)
POLL_INTERVAL_DESKTOP=1
POLL_INTERVAL_BROWSER=5
POLL_INTERVAL_CONNECTORS=900

# ML
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english
USE_LOCAL_INFERENCE=true

# OAuth2 Credentials (per connector)
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
