# Nexus environment variables
# Copy this file to .env and fill in your values.
# Do not set NODE_ENV here. The npm scripts set it explicitly, and Vite warns
# when NODE_ENV is loaded from an env file.

# Core app
PORT=3000
VITE_APP_ID=nexus

# Database
DATABASE_URL=mysql://nexus_user:YOUR_DB_PASSWORD@localhost:3306/nexus

# Auth / session
# Used to sign session JWTs. Use at least 64 random characters.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string_at_least_64_chars
OWNER_OPEN_ID=your_google_oauth_sub_here

# Encryption for user API keys stored in the database
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=generate_64_hex_chars_with_openssl_rand_hex_32

# Google OAuth / sign-in
OAUTH_SERVER_URL=https://accounts.google.com
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Built-in AI provider
BUILT_IN_FORGE_API_URL=https://api.manus.im/v1
BUILT_IN_FORGE_API_KEY=your_manus_forge_key

# Optional provider defaults
# Keep these blank unless you want to provide a platform-wide default.
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
# PERPLEXITY_API_KEY=pplx-...

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_A=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_B=pNInz6obpgDQGcFmaJgB

# Audio file storage
AUDIO_DIR=/var/www/nexus/public/audio
AUDIO_URL_BASE=https://yourdomain.com/audio

# Research service
RESEARCH_SERVICE_URL=http://localhost:8001/api

# Psycho-Behavioral Signal Processor (PBSP) microservice
# Runs on a separate FastAPI service. Leave blank to disable behavioral analysis.
PBSP_SERVICE_URL=http://localhost:8002
PBSP_API_KEY=your_pbsp_api_key

# Search API
EXA_API_KEY=your_exa_api_key

# Backup AI provider (used as fallback when primary is unavailable)
# GEMINI_API_KEY_BACKUP=AIza...

# Optional analytics
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
