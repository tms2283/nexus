# ─── Nexus Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Core App ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
VITE_APP_ID=nexus

# ─── Database ────────────────────────────────────────────────────────────────
# MySQL connection string
DATABASE_URL=mysql://nexus_user:YOUR_DB_PASSWORD@localhost:3306/nexus

# ─── Auth / Session ───────────────────────────────────────────────────────────
# Used to sign session JWTs. Must be at least 64 characters.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string_at_least_64_chars
OWNER_OPEN_ID=your_google_oauth_sub_here

# ─── Encryption (for user API keys stored in DB) ──────────────────────────────
# AES-256-GCM key — REQUIRED. No fallback; server will not start without this.
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=generate_64_hex_chars_with_openssl_rand_hex_32

# ─── OAuth (optional — for login with Google) ────────────────────────────────
OAUTH_SERVER_URL=https://accounts.google.com

# ─── Built-in AI (Manus platform LLM — default, no quota issues) ─────────────
BUILT_IN_FORGE_API_URL=https://api.manus.im/v1
BUILT_IN_FORGE_API_KEY=your_manus_forge_key

# ─── User-supplied AI providers (optional — users can set their own) ─────────
# These are NOT used by the platform directly; users supply them via Settings.
# Keep blank unless you want to set a platform-wide default.
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
# PERPLEXITY_API_KEY=pplx-...

# ─── ElevenLabs (audio overview generation) ───────────────────────────────────
# Get your API key from: https://elevenlabs.io/api
# Starter plan ($5/mo) is sufficient for personal use.
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# Voice IDs — defaults are Rachel (Host A) and Adam (Host B)
# Browse voices at: https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_A=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_B=pNInz6obpgDQGcFmaJgB

# ─── Audio file storage ───────────────────────────────────────────────────────
# Absolute path where generated MP3 files are saved on the server
AUDIO_DIR=/var/www/nexus/public/audio
# Public URL prefix for serving audio files via Nginx
AUDIO_URL_BASE=https://yourdomain.com/audio

# ─── Research Pipeline (Python FastAPI microservice) ─────────────────────────
# URL of the SchmoCo research microservice (runs on same VPS, internal only)
RESEARCH_SERVICE_URL=http://localhost:8001/api

# ─── Search API (for source discovery) ───────────────────────────────────────
# Exa is recommended over Tavily (Tavily was acquired Feb 2026).
# Get your key from: https://exa.ai
EXA_API_KEY=your_exa_api_key

# ─── Analytics (optional — self-hosted Plausible) ────────────────────────────
# Leave blank to disable analytics entirely
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
