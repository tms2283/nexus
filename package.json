{
  "name": "timverse",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "desktop:start": "electron desktop/main.cjs",
    "desktop:dev": "cross-env NODE_ENV=development electron desktop/main.cjs",
    "desktop:pack": "electron-builder --dir",
    "desktop:dist": "electron-builder --win nsis --publish never",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "foundation:assets": "tsx scripts/generate-foundation-assets.ts",
    "ingest:nexus": "tsx scripts/ingest-nexus.ts",
    "ingest:nexus-ed2": "tsx scripts/ingest-nexus-ed2.ts"
  },
