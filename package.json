    "dompurify": "^3.4.1",
    "esbuild": "^0.28.0",
    "follow-redirects": "^1.16.0",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "mdast-util-to-hast": "^13.2.1",
    "path-to-regexp": "0.1.13",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.12",
    "qs": "^6.15.1",
    "tailwindcss": {
      "nanoid": "3.3.7"
    },
    "uuid": "^14.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "electron",
      "electron-builder",
      "electron-winstaller",
      "esbuild"
    ],
    "patchedDependencies": {
      "wouter@3.7.1": "patches/wouter@3.7.1.patch"
    },
    "overrides": {
      "@xmldom/xmldom": "^0.9.10",
      "dompurify": "^3.4.1",
      "esbuild": "^0.28.0",
      "follow-redirects": "^1.16.0",
      "lodash": "^4.18.1",
      "lodash-es": "^4.18.1",
      "mdast-util-to-hast": "^13.2.1",
      "path-to-regexp": "0.1.13",
      "picomatch": "^4.0.4",
      "postcss": "^8.5.12",
      "qs": "^6.15.1",
      "tailwindcss>nanoid": "3.3.7",
      "uuid": "^14.0.0"
    }
  },
  "main": "desktop/main.cjs",
  "build": {
    "appId": "tech.schmo.nexusdesktop",
    "productName": "Nexus Desktop Studio",
    "directories": {
      "output": "desktop-dist"
    },
    "files": [
      "desktop/**/*",
      "package.json"
    ],
    "asar": true,
    "extraMetadata": {
      "main": "desktop/main.cjs"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "nexus-desktop-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
