    "electron": "^41.3.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.0",
    "pnpm": "^10.33.2",
    "postcss": "^8.5.12",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.2.4",
